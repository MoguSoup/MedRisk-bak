# MedRisk AI local development configuration

MYSQL_DATABASE=medrisk
MYSQL_USER=medrisk_app
MYSQL_PASSWORD=ChangeMe_2026!
MYSQL_ROOT_PASSWORD=ChangeRoot_2026!

SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/medrisk?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
SPRING_DATASOURCE_USERNAME=medrisk_app
SPRING_DATASOURCE_PASSWORD=ChangeMe_2026!
MEDRISK_MODEL_SERVICE_URL=http://model-service:8090
MEDRISK_JWT_SECRET=replace-with-at-least-32-characters
MEDRISK_REPORT_DIR=/app/reports
MEDRISK_UPLOAD_DIR=/shared/uploads
MEDRISK_TRAINING_OUTPUT_DIR=/shared/models/training
MEDRISK_ACTIVE_MODELS_FILE=/shared/models/training/active-models.json
MEDRISK_PUBLIC_DATASET_DIR=/shared/data/processed
NEO4J_PASSWORD=medrisk-neo4j
# Docker Compose/med_tencent uses the internal service name below.
# Windows local scripts should use MEDRISK_NEO4J_URI=bolt://localhost:7687 in local .env.
MEDRISK_NEO4J_URI=bolt://neo4j:7687
MEDRISK_NEO4J_USERNAME=neo4j
MEDRISK_NEO4J_PASSWORD=medrisk-neo4j
MEDRISK_NEO4J_DATABASE=neo4j
MEDRISK_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MEDRISK_LLM_API_KEY=
MEDRISK_LLM_MODEL=qwen-plus
MEDRISK_VISION_MODEL=qwen3.5-omni-plus-2026-03-15
MEDRISK_IMAGE_MODEL=wanx-v1
MEDRISK_HTTP_CONNECT_TIMEOUT_MS=5000
MEDRISK_HTTP_READ_TIMEOUT_MS=20000
MEDRISK_IP_BLACKLIST=
# Aliyun Bailian workspace OpenAI-compatible example. Replace only in local/remote .env;
# never commit a real API key.
# MEDRISK_LLM_BASE_URL=https://your-workspace.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# MEDRISK_LLM_API_KEY=replace-with-bailian-api-key
# MEDRISK_LLM_MODEL=qwen-plus
# MEDRISK_VISION_MODEL=qwen3.5-omni-plus-2026-03-15
# MEDRISK_IMAGE_MODEL=wanx-v1
# Optional OpenAI-compatible gateway, for example a cockpit-tools provider gateway.
# Configure only gateway URL/token/model here; never store ChatGPT web login email,
# password, cookies, or browser session data in this project.
# MEDRISK_LLM_BASE_URL=http://127.0.0.1:8787/v1
# MEDRISK_LLM_API_KEY=replace-with-gateway-token
# MEDRISK_LLM_MODEL=gpt-4o-mini
MEDRISK_HF_LLM_ENABLED=false
MEDRISK_HF_QA_MODEL=
MEDRISK_HF_QA_DEVICE=auto
MEDRISK_HF_QA_MAX_NEW_TOKENS=512
MEDRISK_HF_QA_TRUST_REMOTE_CODE=false
MEDRISK_MAIL_HOST=smtp.163.com
MEDRISK_MAIL_PORT=465
MEDRISK_MAIL_USERNAME=
MEDRISK_MAIL_PASSWORD=
MEDRISK_MAIL_FROM=
MEDRISK_MAIL_SSL=true
MEDRISK_MAIL_STARTTLS=false
MEDRISK_MAIL_AUTH=true
MEDRISK_MAIL_AUTH_MECHANISMS=LOGIN
MEDRISK_MAIL_SSL_TRUST=smtp.163.com
MEDRISK_MAIL_CONNECTION_TIMEOUT_MS=10000
MEDRISK_MAIL_READ_TIMEOUT_MS=10000
MEDRISK_MAIL_WRITE_TIMEOUT_MS=10000

VITE_API_BASE_URL=http://localhost:8080/api
MODEL_SERVICE_PORT=8090
BACKEND_PORT=8080
FRONTEND_PORT=5241
